<div class="container py-4">

  <!-- HEADER -->
  <div class="row align-items-center mb-3">
    <!-- Back button -->

    <!-- Title + subtitle -->
    <div class="col-12 col-md-8 col-lg-9 mb-2 mb-md-0">
      <h4 class="fw-bold mb-1"><i class="bi bi-activity me-2 fs-6"></i> Treatment Details</h4>
      <p class="text-muted small mb-0">Complete treatment information and monitoring data</p>
    </div>

    <div class="col-12 col-md-4 col-lg-3">
      <div class="d-flex flex-wrap gap-1 justify-content-md-end">

         <%= link_to treatments_path, class: "btn btn-light btn-sm" do %>
          ← Back
          <% end %>

          <% if current_user.doctor? %>
            <%= link_to edit_treatment_path(@treatment), class: "btn btn-outline-primary btn-sm" do %>
              <i class="bi bi-pencil"></i> Edit
            <% end %>
          <% end %>

        <%= link_to "#", class: "btn btn-dark btn-sm" do %>
          <i class="fa-solid fa-print"></i> Print Report
        <% end %>
      </div>
    </div>
  </div>

  <div class="card border mt-4 p-3">
    <div class="row">
      <div class="col-md-6">
        <h5><strong><%= @treatment.treatment_name.humanize %></strong></h5>

        <p class="mb-1"><strong>Indication:</strong>
          <%= @treatment.diagnosis&.primary_diagnosis.humanize || "NA" %>
        </p>
        <p class="mb-1"><strong>Frequency:</strong>
          <%= @treatment.frequency.humanize.presence || "NA" %>
        </p>
      </div>

      <div class="col-12 col-md-6 mt-2">
        <div class="d-flex flex-wrap gap-2 justify-content-start justify-content-md-end">
          
          <span class="badge bg-light text-primary">
            <%= @treatment.treatment_type.humanize %>
          </span>

          <span class="badge <%= @treatment.status == 'Active' ? 'bg-success' : 'bg-secondary' %>">
            <%= @treatment.status.humanize %>
          </span>

        </div>
      </div>
    </div>
  </div>

  <!-- PATIENT INFO -->
  <div class="card border mt-2 mb-2 p-3">
    <div class="d-flex align-items-center mb-3">
      <div class="rounded-circle bg-light d-flex align-items-center justify-content-center me-2"
           style="width: 35px; height: 35px;">
        <i class="bi bi-person text-primary"></i>
      </div>
      <h5 class="mb-0 fw-bold">Patient Information</h5>
    </div>

    <div class="row">
      <div class="col-md-4">
        <small class="text-muted">Patient Name</small>
        <p class="fw-semibold mb-2">
          <%= @treatment.patient.full_name %>
        </p>
      </div>

      <div class="col-md-4">
        <small class="text-muted">Patient ID</small>
        <p class="fw-semibold mb-0">
          P<%= @treatment.patient.id.to_s.rjust(3, "0") %>
        </p>
      </div>

      <div class="col-md-4">
        <small class="text-muted">Prescribed By</small>
        <p class="fw-semibold mb-0">
          Dr. <%= @treatment.doctor.full_name %>
        </p>
      </div>
    </div>
  </div>

  <div class="row g-3">
    <!-- Prescription Details -->
    <div class="col-md-6">
      <div class="card p-3 border rounded">
        <h6 class="fw-bold mb-3">💊 Prescription Details</h6>
        <p class="mb-1"><strong>Dosage:</strong> <%= @treatment.dosage.humanize || "NA" %></p>
        <p class="mb-1"><strong>Frequency:</strong> <%= @treatment.frequency.humanize || "NA" %></p>
        <p class="mb-1"><strong>Route:</strong> Oral</p>
        <p class="mb-1"><strong>Status:</strong>
          <span class="badge <%= @treatment.status == 'Active' ? 'bg-success' : 'bg-secondary' %>"><%= @treatment.status %></span>
        </p>
      </div>
    </div>

    <!-- Timeline -->
    <div class="col-md-6">
      <div class="card p-3 border rounded">
        <h6 class="fw-bold mb-3">📅 Treatment Timeline</h6>
        <p class="mb-1"><strong>Start Date:</strong> <%= @treatment.treatment_start_date %></p>
        <p class="mb-1"><strong>End Date:</strong> Ongoing</p>
        <p class="mb-1">
          <span class="badge bg-warning text-dark">
            ⏳ Next Review: <%= @treatment.next_review_date %>
          </span>
        </p>
      </div>
    </div>
  </div>

  <!-- Side Effects -->
  <div class="col-md-12">
    <div class="card mt-2 mb-2 p-3 border rounded">
      <h6 class="fw-bold text-danger">⚠️ Reported Side Effects</h6>
      <div class="bg-danger-subtle p-2 rounded small" style="overflow-wrap: anywhere;">
        <%= @treatment.description.humanize || "No notes available" %>
      </div>
      <small class="text-muted d-block mt-2">
        Monitor patient for side effects. Contact physician if symptoms worsen.
      </small>
    </div>
  </div>

  <!-- Clinical Notes -->
  <div class="col-md-12">
    <div class="card mt-2 mb-2 p-3 border rounded">
      <h6 class="fw-bold">📝 Clinical Notes</h6>
      <div class="bg-light p-2 rounded mt-2">
        <%= @treatment.clinical_notes.humanize || "No notes available" %>
      </div>
    </div>
  </div>

  <!-- Active Treatment -->
  <div class="col-md-12">
    <div class="card mt-2 mb-2 p-3 border rounded">
      <h6 class="fw-bold text-primary">🚀 Active Treatment</h6>
      <p class="mb-0">
        This treatment is currently active and ongoing. Patient is being monitored regularly.
      </p>
    </div>
  </div>

  <!-- Safety & Monitoring -->
  <div class="col-md-12">
    <div class="card mt-2 mb-2 p-3 border rounded">
      <h6 class="fw-bold">🛡️ Safety & Monitoring</h6>

      <div class="row mt-2">
        <div class="col-md-6 mb-1">
          <div class="border rounded p-2 bg-light">
            <small class="text-muted">Monitoring Schedule</small>
            <p class="mb-0"><%= @treatment.next_review_date %></p>
          </div>
        </div>

        <div class="col-md-6 mb-1">
          <div class="border rounded p-2 bg-light">
            <small class="text-muted">Treatment Duration</small>
            <p class="mb-0"><%= @treatment.duration || "Ongoing" %></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>