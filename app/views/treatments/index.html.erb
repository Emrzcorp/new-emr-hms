<div class="container my-4">

  <!-- Header -->
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
    <div class="mb-3 mb-md-0">
      <h3 class="mb-0"><i class="bi bi-activity me-1"></i>Treatment Management</h3>
      <small class="text-muted">Monitor and manage patient treatments and medications</small>
    </div>

    <% if current_user.doctor? %>
      <%= link_to new_treatment_path, class: 'btn btn-primary btn-sm mb-2 rounded-3', data: { bs_toggle: 'modal', bs_target: "#treatmentModal" }  do %>
          <i class="fa-solid fa-plus me-2"></i> Add New Patients
      <% end %>
    <% end %>

    <!-- Modal -->
    <div class="modal fade" id="treatmentModal" tabindex="-1" aria-labelledby="treatmentModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h1 class="modal-title fs-5" id="treatmentModalLabel"><i class="bi bi-activity me-1"></i> Add New Treament
              <br>
              <p class="text-muted fs-6">Create a new treatment plan for a patient.</p>
            </h1>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <%= render 'treatments/form', treatment: @treatment %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Summary Cards -->
  <div class="row g-3 mb-4">
    <div class="col-md-3">
      <div class="card-summary text-start border-0 p-3 rounded-3" style="background:#eaf3ff;">
        <div class="d-flex justify-content-between">
          <div>
            <small>Total Treatments</small>
            <h4 class="fw-bold mt-2"><%= @total_treatments %></h4>
            <small class="text-primary">All treatment records</small>
          </div>
          <i class="fa-solid fa-bolt text-primary"></i>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card-summary text-start border-0 p-3 rounded-3" style="background:#eafbf1;">
        <div class="d-flex justify-content-between">
          <div>
            <small>Active Treatments</small>
            <h4 class="fw-bold mt-2"><%= @active_treatments %></h4>
            <small class="text-success">Currently ongoing</small>
          </div>
          <i class="fa-solid fa-circle-check text-success"></i>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card-summary text-start border-0 p-3 rounded-3" style="background:#f6efff;">
        <div class="d-flex justify-content-between">
          <div>
            <small>Medications</small>
            <h4 class="fw-bold mt-2"><%= @medications_count %></h4>
            <small class="text-info">Prescribed medications</small>
          </div>
          <i class="fa-solid fa-capsules text-purple"></i>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card-summary text-start border-0 p-3 rounded-3" style="background:#fff5eb;">
        <div class="d-flex justify-content-between">
          <div>
            <small>Completed</small>
            <h4 class="fw-bold mt-2"><%= @completed_treatments %></h4>
            <small class="text-warning">Finished treatments</small>
          </div>
          <i class="fa-solid fa-clock text-warning"></i>
        </div>
      </div>
    </div>
  </div>

  <!-- Filter Tabs -->
  <div class="mb-3">
    <button class="btn btn-light btn-sm rounded-pill px-3 mb-1">All Treatments</button>
    <button class="btn btn-light btn-sm rounded-pill px-3 mb-1">By Type</button>
    <button class="btn btn-light btn-sm rounded-pill px-3 mb-1">Adherence Tracking</button>
  </div>

  <!-- Search Filters -->
  <%= render 'treatments/search' %>

  <!-- Treatment Cards -->
  <% if @treatments.present? %>
    <div class="row g-3">
      <% @treatments.each do |t| %>
        <div class="col-12">
          <div class="card border rounded-3 p-3 h-100 shadow-none">

            <!-- HEADER -->
            <div class="d-flex justify-content-between align-items-start flex-wrap mb-2">
              
              <!-- LEFT -->
              <div class="d-flex align-items-center mb-2">
                <div>
                  <h5 class="mb-0"><i class="fa-solid fa-link text-primary me-2"></i>
                    <%= t.treatment_name.humanize %></h5>

                  <small class="text-muted">
                    <%= t.patient&.full_name || "N/A" %> • 
                    <%= t.diagnosis&.primary_diagnosis || "No Diagnosis" %>
                  </small>
                </div>
              </div>

              <!-- RIGHT BADGES -->
              <div class="text-end">
                <span class="badge bg-light text-dark mb-1">
                  <%= t.treatment_type.humanize %>
                </span>

                <span class="badge <%= t.status == 'Active' ? 'bg-success' : 'bg-secondary' %>">
                  <%= t.status.humanize %>
                </span>
              </div>
            </div>

            <hr>

            <!-- DETAILS -->
            <div class="row mb-3">
              <div class="col-12 col-sm-6">
                <div class="section-title fw-bold mb-1">Treatment Details</div>
                <p class="mb-1"><strong>Dosage:</strong> <%= t.dosage.presence || "NA" %></p>
                <p class="mb-1"><strong>Frequency:</strong> <%= t.frequency.presence || "NA" %></p>
                <p class="mb-1"><strong>Route:</strong> Oral</p>
                <p class="mb-1"><strong>Doctor:</strong> Dr. <%= t.doctor&.full_name || "N/A" %></p>
              </div>

              <div class="col-12 col-sm-6">
                <div class="section-title fw-bold mb-1">Timeline</div>
                <p class="mb-1"><strong>Start:</strong> <%= t.treatment_start_date %></p>
                <p class="mb-1"><strong>Next Review:</strong> <%= t.next_review_date || "NA" %></p>
              </div>
            </div>

            <!-- NOTES -->
            <% if t.clinical_notes.present? %>
              <div class="fw-bold mb-1">Notes</div>
              <div class="bg-light p-2 rounded small mb-3">
                <%= t.clinical_notes.humanize %>
              </div>
            <% end %>

            <!-- FOOTER -->
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 pt-2 border-top">

              <div class="small">
                <strong>ID:</strong> 
                <span class="text-primary fw-semibold">
                  <%= t.patient&.id.to_s.rjust(3, "0") rescue "NA" %>
                </span> •
                <strong>Review:</strong> 
                <span class="text-primary fw-semibold">
                  <%= t.next_review_date || "NA" %>
                </span>
              </div>

              <div class="d-flex gap-2">
                <% if current_user.doctor? %>
                  <%= link_to edit_treatment_path(t), class: "btn btn-outline-primary btn-sm" do %>
                    <i class="bi bi-pencil"></i>
                  <% end %>
                <% end %>

                <%= link_to treatment_path(t), class: "btn btn-primary btn-sm" do %>
                  <i class="bi bi-eye"></i>
                <% end %>
              </div>

            </div>

          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="alert alert-info mt-4 text-center">No Treatment detail found.</div>
  <% end %>

  <% if @treatments %>
    <div class="col-lg-12 mt-3 mb-3">
      <div class="d-flex justify-content-between bg-light rounded align-items-center py-3">
        <div class="page_info ms-3 text-black">
          <%= page_entries_info @treatments %>
        </div>
        <% if params[:per_page ].present? %>
          <%= will_paginate @treatments, :params =>  {per_page: @per_page }, renderer: WillPaginate::ActionView::BootstrapLinkRenderer %>
        <% else %>
          <%= will_paginate @treatments, renderer: WillPaginate::ActionView::BootstrapLinkRenderer %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>