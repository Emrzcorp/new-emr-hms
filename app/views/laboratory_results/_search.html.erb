<%= form_with url: laboratory_results_path, method: :get, local: true do %>
  <div class="card border rounded-3 p-3 mb-4">
    <h5>Search & Filter Test Results</h5>
    <small class="text-muted">Find specific test results using search and filter options</small>

    <div class="row mt-3 g-2">
      <div class="col-12 col-md-6">
        <%= text_field_tag :query, params[:query],
              class: "form-control",
              placeholder: "Search by patient, test name, type...", autocomplete: "off" %>
      </div>

      <div class="col-6 col-md-2">
        <%= select_tag :test_type,
            options_for_select(
              [["All Types", ""]] +
              LaboratoryResult::TEST_TYPES.map { |v| [v, v] },
              params[:test_type]
            ),
            class: "form-select",
            onchange: "this.form.submit();" %>
      </div>

      <div class="col-6 col-md-2">
        <%= select_tag :status,
            options_for_select(
              [["All Types", ""]] +
              LaboratoryResult::STATUS.map { |v| [v, v] },
              params[:status]
            ),
            class: "form-select",
            onchange: "this.form.submit();" %>
      </div>

      <div class="col-6 col-md-2">
        <%= date_field_tag :test_date, params[:test_date],
              class: "form-control",
              onchange: "this.form.submit();" %>
      </div>

      <div class="col-12 col-md-2">
        <%= submit_tag "Search", class: "btn btn-primary btn-md" %>
        <%= link_to "Reset", laboratory_results_path, class: "btn btn-outline-secondary btn-md" %>
      </div>

    </div>
  </div>
<% end %>