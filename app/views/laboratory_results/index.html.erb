<div class="container my-4">

  <!-- Header -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h3 class="fw-bold mb-0">
        <i class="fa-solid fa-vial"></i>
        Laboratory Results
      </h3>
      <small class="text-muted">
        View and manage patient test results and lab reports
      </small>
    </div>

    <%= link_to new_laboratory_result_path, class: 'btn btn-primary btn-sm rounded-3 mb-2', data: { bs_toggle: 'modal', bs_target: "#treatmentModal" }  do %>
        <i class="fa-solid fa-plus me-2"></i> Order New Test
      <% end %>

      <!-- Modal -->
      <div class="modal fade" id="treatmentModal" tabindex="-1" aria-labelledby="treatmentModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
          <div class="modal-content">
            <div class="modal-header">
              <h1 class="modal-title fs-5" id="treatmentModalLabel"><i class="fa-solid fa-vial me-1"></i> Add Test Result
                <br>
                <p class="text-muted fs-6">Record a new test result for a patient.</p>
              </h1>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
              <%= render 'laboratory_results/form', result: @result %>
            </div>
          </div>
        </div>
      </div>
  </div>

  <!-- Summary Cards -->
  <div class="row g-3 mb-4">
    <div class="col-md-3">
      <div class="card-summary text-start border-0 shadow-sm p-3 rounded-4" style="background:#eaf3ff;">
        <div class="d-flex justify-content-between">
          <div>
            <small>Total Tests</small>
            <h4 class="fw-bold mt-2"><%= @total_tests %></h4>
            <small class="text-primary">All test orders</small>
          </div>
          <i class="fa-solid fa-bolt text-primary"></i>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card-summary text-start border-0 shadow-sm p-3 rounded-4" style="background:#eafbf1;">
        <div class="d-flex justify-content-between">
          <div>
            <small>Completed</small>
            <h4 class="fw-bold mt-2"><%= @completed %></h4>
            <small class="text-success">Results available</small>
          </div>
          <i class="fa-solid fa-circle-check text-success"></i>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card-summary text-start border-0 shadow-sm p-3 rounded-4" style="background:#f6efff;">
        <div class="d-flex justify-content-between">
          <div>
            <small>Pending</small>
            <h4 class="fw-bold mt-2"><%= @pending %></h4>
            <small class="text-info">Awaiting results</small>
          </div>
          <i class="fa-solid fa-capsules text-purple"></i>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card-summary text-start border-0 shadow-sm p-3 rounded-4" style="background:#fff5eb;">
        <div class="d-flex justify-content-between">
          <div>
            <small>Abnormal</small>
            <h4 class="fw-bold mt-2"><%= @abnormal %></h4>
            <small class="text-warning">Require attention</small>
          </div>
          <i class="fa-solid fa-clock text-warning"></i>
        </div>
      </div>
    </div>
  </div>

  <!-- Search Filters -->
  <div class="card border-0 shadow-sm rounded-4 p-3 mb-4">
    <h6 class="fw-bold">Search & Filter Test Results</h6>
    <small class="text-muted">Find specific test results using search and filter options</small>

    <div class="row mt-3">
      <div class="col-md-8">
        <%#= form_with url: laboratory_results_path, method: :get, local: true do %>
          <%#= text_field_tag :query, params[:query],
                class: "form-control",
                placeholder: "Search by patient name..." %>
      </div>

      <div class="col-md-2">
          <%#= select_tag :treatment_type,
                options_for_select(["All Types","Medication","Therapy"], params[:treatment_type]),
                class: "form-select" %>
      </div>

      <div class="col-md-2">
          <%#= select_tag :status,
                options_for_select(["All Statuses","Active","Completed"], params[:status]),
                class: "form-select" %>
        <%# end %>
      </div>
    </div>
  </div>

  <!-- Treatment Cards -->
  <% if @results.present? %>
    <% @results.each do |t| %>
      <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
        
        <!-- Top -->
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <h5 class="fw-bold mb-1">
              <i class="fa-solid fa-vial text-primary me-2"></i>
              <%= t.test_name.humanize %>
            </h5>
            <small class="text-muted">
              <%= t.patient.full_name %> • <%= t.test_type || "NA" %>
            </small>
          </div>

          <div>
            <% case t.status %>
            <% when "Completed" %>
              <span class="badge bg-success">Completed</span>
            <% when "Pending" %>
              <span class="badge bg-warning text-dark">Pending</span>
            <% when "In Progress" %>
              <span class="badge bg-info text-dark">In Progress</span>
            <% else %>
              <span class="badge bg-secondary"><%= t.status %></span>
            <% end %>

            <!-- Priority -->
            <% case t.priority %>
            <% when "Stat" %>
              <span class="badge bg-danger">Stat</span>
            <% when "Urgent" %>
              <span class="badge bg-warning text-dark">Urgent</span>
            <% else %>
              <span class="badge bg-secondary">Routine</span>
            <% end %>
          </div>
        </div>

        <!-- Middle -->
        <div class="row mt-4">
          <div class="col-md-6">
            <h6 class="fw-bold">Test Information</h6>
            <p class="mb-1"><strong>Ordered:</strong> <%= t.test_date %></p>
            <p class="mb-1"><strong>Sample Date:</strong> <%#= t.test_date %></p>
            <p class="mb-1"><strong>Result Date:</strong> </p>
            <p class="mb-1"><strong>Ordered by:</strong> Dr. <%= t.doctor.full_name %></p>
          </div>

          <div class="col-md-6">
            <h6 class="fw-bold">Test Results</h6>

            <% if t.results.present? %>

              <% rows = t.results.split("\n") %>

              <% rows.first(3).each do |row| %>
                <% name, value, range = row.split("|") %>

                <div class="d-flex justify-content-between align-items-center p-2 mb-2 rounded"
                     style="background-color: #f8f9fa; font-size: 0.85rem;">

                  <!-- LEFT -->
                  <div class="d-flex align-items-center py-1">
                    <i class="bi bi-check-circle-fill text-success me-2" style="font-size: 0.75rem;"></i>
                    <span><%= name %></span>
                  </div>

                  <!-- RIGHT -->
                  <div class="text-end">
                    <div class="fw-semibold text-success">
                      <%= value %>
                    </div>
                    <%# <small class="text-muted"> %>
                      <%# Ref: <%#= range %>
                    <%# </small> %>
                  </div>

                </div>
              <% end %>

              <% if rows.size > 3 %>
                <small class="text-muted">+ <%= rows.size - 3 %> more</small>
              <% end %>

            <% else %>
              <p class="text-muted">No results</p>
            <% end %>

          </div>

          <div class="mt-2">
            <strong>Clinical Notes:</strong>
            <div class="border rounded bg-light p-2 mt-1" style="min-height: 50px;">
              <%= t.additional_notes.titleize.presence || "NA" %>
            </div>
          </div>
        </div>

        <!-- Bottom -->
        <div class="d-flex justify-content-between align-items-center mt-4">
          <div>
            <small class="text-muted me-3">
              <i class="fa-solid fa-user"></i>
              <%= t.patient.id.to_s.rjust(3, "0") || "NA" %>
            </small>
            <small class="text-muted">
              <%# <i class="fa-solid fa-calendar"></i> %>
              <%# Review: <%#= t.next_review_date %>
            </small>
          </div>

          <div>
            <%= link_to edit_laboratory_result_path(t), class: "btn btn-outline-secondary btn-sm" do %>
              <i class="bi bi-pencil"></i> Edit
            <% end %>

            <%= link_to laboratory_result_path(t), class: "btn btn-primary btn-sm" do %>
              <i class="bi bi-eye"></i> View
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="alert alert-info mt-4 text-center">No Treatment detail found.</div>
  <% end %>
</div>