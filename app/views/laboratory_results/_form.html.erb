<div class="container">

  <%= form_with model: result, scope: :laboratory_result, data: { turbo_frame: "_top" } do |f| %>

    <h5>Patient Information</h5>

    <div class="row">
      <div class="col-md-6">
        <%= f.label :patient_id, "Patient *" %>

        <%= f.collection_select :patient_id,
          @patients || [],
          :id,
          :full_name,
          { prompt: "Select Patient" },
          class: "form-select #{'is-invalid' if result.errors[:patient_id].present?}" %>

        <% if result.errors[:patient_id].present? %>
          <div class="invalid-feedback d-block">
            <%= result.errors.full_messages_for(:patient_id).first %>
          </div>
        <% end %>
      </div>

      <div class="col-md-6">
        <%= f.label :test_date, "Test Date *" %>

        <%= f.date_field :test_date,
          class: "form-control #{'is-invalid' if result.errors[:test_date].present?}" %>

        <% if result.errors[:test_date].present? %>
          <div class="invalid-feedback d-block">
            <%= result.errors.full_messages_for(:test_date).first %>
          </div>
        <% end %>
      </div>
    </div>

    <h5 class="mt-3">Test Details</h5>

    <div class="row">
      <div class="col-md-6">
        <%= f.label :test_type, "Test Type *" %>

        <%= f.select :test_type,
          LaboratoryResult::TEST_TYPES,
          { prompt: "Select Test Type" },
          class: "form-select #{'is-invalid' if result.errors[:test_type].present?}" %>

        <% if result.errors[:test_type].present? %>
          <div class="invalid-feedback d-block">
            <%= result.errors.full_messages_for(:test_type).first %>
          </div>
        <% end %>
      </div>

      <div class="col-md-6">
        <%= f.label :test_name, "Test Name *" %>

        <%= f.text_field :test_name,
          placeholder: "Test Name",
          class: "form-control #{'is-invalid' if result.errors[:test_name].present?}" %>

        <% if result.errors[:test_name].present? %>
          <div class="invalid-feedback d-block">
            <%= result.errors.full_messages_for(:test_name).first %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="row mt-2">
      <div class="col-md-6">
        <%= f.label :facility, "Laboratory/Facility *" %>

        <%= f.text_field :facility,
          placeholder: "Lab / Facility",
          class: "form-control #{'is-invalid' if result.errors[:facility].present?}" %>

        <% if result.errors[:facility].present? %>
          <div class="invalid-feedback d-block">
            <%= result.errors.full_messages_for(:facility).first %>
          </div>
        <% end %>
      </div>

      <div class="col-md-6">
        <%= f.label :status, "Status *" %>

        <%= f.select :status,
          LaboratoryResult::STATUS,
          { prompt: "Select Status" },
          class: "form-select #{'is-invalid' if result.errors[:status].present?}" %>

        <% if result.errors[:status].present? %>
          <div class="invalid-feedback d-block">
            <%= result.errors.full_messages_for(:status).first %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="row mt-2">
      <div class="col-md-6">
        <%= f.label :priority, "Priority *" %>

        <%= f.select :priority,
          LaboratoryResult::PRIORITY,
          { prompt: "Select Priority" },
          class: "form-select #{'is-invalid' if result.errors[:priority].present?}" %>

        <% if result.errors[:priority].present? %>
          <div class="invalid-feedback d-block">
            <%= result.errors.full_messages_for(:priority).first %>
          </div>
        <% end %>
      </div>

      <div class="col-md-6">
        <%= f.label :test_price, "Test Price *" %>

        <%= f.number_field :test_price,
          step: 0.01,
          class: "form-control #{'is-invalid' if result.errors[:test_price].present?}",
          placeholder: "Enter test price" %>

        <% if result.errors[:test_price].present? %>
          <div class="invalid-feedback d-block">
            <%= result.errors.full_messages_for(:test_price).first %>
          </div>
        <% end %>
      </div>
    </div>

    <h5 class="mt-3">Test Results</h5>

    <%= f.label :results, "Results" %>

    <%= f.text_area :results,
      class: "form-control #{'is-invalid' if result.errors[:results].present?}",
      placeholder: "Results" %>

    <% if result.errors[:results].present? %>
      <div class="invalid-feedback d-block">
        <%= result.errors.full_messages_for(:results).first %>
      </div>
    <% end %>

    <%= f.label :reference_range, "Reference Range", class: "mt-2" %>

    <%= f.text_field :reference_range,
      class: "form-control #{'is-invalid' if result.errors[:reference_range].present?}",
      placeholder: "Reference Range" %>

    <% if result.errors[:reference_range].present? %>
      <div class="invalid-feedback d-block">
        <%= result.errors.full_messages_for(:reference_range).first %>
      </div>
    <% end %>

    <%= f.label :clinical_interpretation, "Clinical Interpretation", class: "mt-2" %>

    <%= f.text_area :clinical_interpretation,
      class: "form-control #{'is-invalid' if result.errors[:clinical_interpretation].present?}",
      placeholder: "Clinical Interpretation" %>

    <% if result.errors[:clinical_interpretation].present? %>
      <div class="invalid-feedback d-block">
        <%= result.errors.full_messages_for(:clinical_interpretation).first %>
      </div>
    <% end %>

    <%= f.label :additional_notes, "Additional Notes", class: "mt-2" %>

    <%= f.text_area :additional_notes,
      class: "form-control #{'is-invalid' if result.errors[:additional_notes].present?}",
      placeholder: "Notes" %>

    <% if result.errors[:additional_notes].present? %>
      <div class="invalid-feedback d-block">
        <%= result.errors.full_messages_for(:additional_notes).first %>
      </div>
    <% end %>

    <h5 class="mt-3">Flags & Follow-up</h5>

    <div class="form-check">
      <%= f.check_box :abnormal, class: "form-check-input" %>
      <%= f.label :abnormal, "Abnormal", class: "form-check-label" %>
    </div>

    <div class="form-check">
      <%= f.check_box :critical, class: "form-check-input" %>
      <%= f.label :critical, "Critical", class: "form-check-label" %>
    </div>

    <div class="form-check">
      <%= f.check_box :follow_up_required, class: "form-check-input" %>
      <%= f.label :follow_up_required, "Follow-up Required", class: "form-check-label" %>
    </div>

    <div class="mt-3">
      <%= f.submit "Save", class: "btn btn-primary" %>
      <%= link_to "Cancel", laboratory_results_path, class: "btn btn-secondary" %>
    </div>

  <% end %>
</div>