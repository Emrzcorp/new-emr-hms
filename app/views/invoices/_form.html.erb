<div class="container">
	<%= form_with model: invoice do |f| %>
  <% if invoice.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% invoice.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card p-3 border rounded-3 mb-3">
    <h5>Invoice Details</h5>

    <div class="row">
      <div class="col-md-6 mb-2">
        <%= f.label :patient_id, "Patient" %>
        <%= f.collection_select :patient_id, @patients, :id, :full_name,
          { prompt: "Select patient" },
          class: "form-select" %>
      </div>

      <div class="col-md-6 mb-2">
        <%= f.label :invoice_type %>
        <%= f.select :invoice_type, Invoice::INVOICE_TYPES,
          { prompt: "Select invoice type" },
          class: "form-select" %>
      </div>

      <div class="col-md-6 mb-2">
        <%= f.label :invoice_date %>
        <%= f.date_field :invoice_date, class: "form-control" %>
      </div>

      <div class="col-md-6 mb-2">
        <%= f.label :valid_until, "Valid Until" %>
        <%= f.date_field :valid_until, class: "form-control" %>
      </div>
    </div>
  </div>

  <div class="card p-3 border rounded-3 mb-3">
    <h5>Invoice Items</h5>

    <%= f.fields_for :invoice_items do |item| %>
      <div class="row mb-2">
        <div class="col-md-4">
          <%= item.label :item_name %>
          <%= item.text_field :item_name, class: "form-control", placeholder: "Consultation Fee / Blood Test / Medicine" %>
        </div>

        <div class="col-md-2">
          <%= item.label :quantity %>
          <%= item.number_field :quantity, class: "form-control", value: item.object.quantity || 1 %>
        </div>

        <div class="col-md-3">
          <%= item.label :unit_price %>
          <%= item.number_field :unit_price, step: 0.01, class: "form-control" %>
        </div>

        <div class="col-md-3">
          <%= item.label :description %>
          <%= item.text_field :description, class: "form-control" %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="card p-3 border rounded-3 mb-3">
    <h5>Payment</h5>

    <div class="row">
      <div class="col-md-4 mb-2">
        <%= f.label :discount_amount %>
        <%= f.number_field :discount_amount, step: 0.01, class: "form-control" %>
      </div>

      <div class="col-md-4 mb-2">
        <%= f.label :tax_amount %>
        <%= f.number_field :tax_amount, step: 0.01, class: "form-control" %>
      </div>

      <div class="col-md-4 mb-2">
        <%= f.label :paid_amount %>
        <%= f.number_field :paid_amount, step: 0.01, class: "form-control" %>
      </div>

      <div class="col-md-6 mb-2">
        <%= f.label :payment_method %>
        <%= f.select :payment_method, Invoice::PAYMENT_METHODS,
          { prompt: "Select payment method" },
          class: "form-select" %>
      </div>

      <div class="col-md-6 mb-2">
        <%= f.label :notes %>
        <%= f.text_area :notes, class: "form-control", rows: 1 %>
      </div>
    </div>
  </div>

  <%= f.submit "Save Invoice", class: "btn btn-primary" %>
  <%= link_to "Cancel", invoices_path, class: "btn btn-secondary" %>
<% end %>
</div>