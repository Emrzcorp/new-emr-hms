<div class="container my-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <h3 class="fw-bold">
        <i class="bi bi-receipt me-2"></i> Billing & Invoices
      </h3>
      <small class="text-muted">Manage consultation, lab and pharmacy billing</small>
    </div>

    <% if current_user.doctor? || current_user.admin? %>
      <%= link_to new_invoice_path, class: "btn btn-primary btn-sm rounded-3" do %>
      	<i class="fa-solid fa-plus me-1"></i> Create Invoice 
      <% end %>
    <% end %>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
      <div class="card-summary text-start p-3 rounded-4 shadow-sm bg-light">
        <small class="fs-6 fw-bold">Total Revenue</small>
        <h5 class="mt-2">₹<%= @total_revenue %></h5>
      </div>
    </div>

    <div class="col-6 col-md-3">
      <div class="card-summary text-start p-3 rounded-4 shadow-sm" style="background:#fff4e5;">
        <small class="fs-6 fw-bold">Pending Amount</small>
        <h5 class="mt-2">₹<%= @pending_amount %></h5>
      </div>
    </div>

    <div class="col-6 col-md-3">
      <div class="card-summary text-start p-3 rounded-4 shadow-sm" style="background:#e6f9e8;">
        <small class="fs-6 fw-bold">Paid Invoices</small>
        <h5 class="mt-2"><%= @paid_count %></h5>
      </div>
    </div>

    <div class="col-6 col-md-3">
      <div class="card-summary text-start p-3 rounded-4 shadow-sm" style="background:#f8d7da;">
        <small class="fs-6 fw-bold">Unpaid Invoices</small>
        <h5 class="mt-2"><%= @unpaid_count %></h5>
      </div>
    </div>
  </div>

  <div class="table-responsive">
    <table class="table table-hover align-middle">
      <thead class="table-light">
        <tr>
          <th>Invoice</th>
          <th>Patient</th>
          <th>Type</th>
          <th>Date</th>
          <th>Total</th>
          <th>Paid</th>
          <th>Status</th>
          <th>Method</th>
          <th>Actions</th>
        </tr>
      </thead>

      <tbody>
        <% @invoices.each do |invoice| %>
          <tr>
            <td><%= invoice.invoice_number %></td>
            <td><%= invoice.patient&.full_name %></td>
            <td><%= invoice.invoice_type %></td>
            <td><%= invoice.invoice_date %></td>
            <td>₹<%= invoice.total_amount %></td>
            <td>₹<%= invoice.paid_amount %></td>
            <td>
              <% case invoice.payment_status %>
              <% when "paid" %>
                <span class="badge bg-success">Paid</span>
              <% when "partial" %>
                <span class="badge bg-warning text-dark">Partial</span>
              <% else %>
                <span class="badge bg-danger">Unpaid</span>
              <% end %>
            </td>
            <td><%= invoice.payment_method || "NA" %></td>
            <td>
              <%= link_to "View", invoice_path(invoice), class: "btn btn-outline-primary btn-sm" %>

              <% if current_user.doctor? || current_user.admin? %>
                <%= link_to "Edit", edit_invoice_path(invoice), class: "btn btn-outline-secondary btn-sm" %>
              <% end %>

              <%= link_to download_pdf_invoice_path(invoice),
							    class: "btn btn-outline-dark btn-sm",
							    target: "_blank" do %>
							  <i class="bi bi-file-earmark-pdf"></i>
							<% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="mt-3">
    <%= will_paginate @invoices, renderer: WillPaginate::ActionView::BootstrapLinkRenderer %>
  </div>
</div>