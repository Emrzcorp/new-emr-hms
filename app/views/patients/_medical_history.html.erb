<div class="col-12 col-md-7 col-lg-9 text-center text-md-start mb-2 mb-md-0">
  <h4 class="fw-bold mb-1"><i class="bi bi-file-earmark-text me-2 fs-5"></i> Medical History</h4>
  <p class="text-muted small mb-0">Complete medical history and visit records</p>
</div>

<% if medical_records.present? %>
  <% medical_records.each do |record| %>
    <div class="card mb-3 mt-3 shadow-sm border rounded-3 p-3">

      <!-- Header -->
      <div class="d-flex justify-content-between mb-2">
        <div>
          <h6 class="fw-bold mb-1">
            <%= record.diagnosis.humanize.presence || "NA" %>
          </h6>
          <small class="text-muted">
            Dr. <%= record.doctor.full_name.presence || "NA" %> • 
            <%= record.visit_date.strftime("%Y-%m-%d") if record.visit_date.presence || "NA" %>
          </small>
        </div>

        <div class="mt-2">
          <span class="badge bg-light text-dark p-2">
            <%= record.visit_type.humanize.presence || "NA" %>
          </span>
        </div>
      </div>

      <p class="mt-2 mb-3 bg-danger-subtle p-2 rounded">
        <%= record.clinical_notes.humanize.presence || "No notes available" %>
      </p>

      <!-- Vitals -->
      <div class="row text-center">

        <div class="col-md-3 mb-2">
          <div class="p-2 rounded bg-light">
            <small>Blood Pressure</small>
            <div class="fw-bold text-danger"><%= record.blood_pressure.presence || "NA" %></div>
          </div>
        </div>

        <div class="col-md-3 mb-2">
          <div class="p-2 rounded bg-light">
            <small>Heart Rate</small>
            <div class="fw-bold text-primary"><%= record.heart_rate.presence || "NA" %></div>
          </div>
        </div>

        <div class="col-md-3 mb-2">
          <div class="p-2 rounded bg-light">
            <small>Temperature</small>
            <div class="fw-bold text-success"><%= record.temperature.presence || "NA" %></div>
          </div>
        </div>

        <div class="col-md-3 mb-2">
          <div class="p-2 rounded bg-light">
            <small>Weight</small>
            <div class="fw-bold text-purple"><%= record.weight.presence || "NA" %></div>
          </div>
        </div>

      </div>
    </div>
  <% end %>
<% else %>
  <div class="alert alert-info mt-2">No medical records found.</div>
<% end %>