<%= form_with url: patients_path, method: :get, local: true do %>
  <div class="row g-2 mb-3">

    <!-- 🔍 Search -->
    <div class="col-12 col-md-6">
      <%= text_field_tag :query, params[:query],
        class: "form-control",
        placeholder: "Search patients by name, email, or phone...", autocomplete: "off" %>
    </div>

    <!-- 📌 Status -->
    <div class="col-6 col-md-2">
      <%= select_tag :status,
        options_for_select(
          [["All Status", ""], ["Active", "active"], ["Inactive", "inactive"]],
          params[:status]
        ),
        class: "form-select",
        onchange: "this.form.submit();" %>
    </div>

    <!-- 📌 Priority -->
    <div class="col-6 col-md-2">
      <%= select_tag :priority,
        options_for_select(
          [["All Priority", ""], ["High", "high"], ["Medium", "medium"], ["Low", "low"]],
          params[:priority]
        ),
        class: "form-select",
        onchange: "this.form.submit();" %>
    </div>

    <!-- Buttons -->
    <div class="col-12 col-md-2">
      <%= submit_tag "Search", class: "btn btn-primary btn-md" %>
      <%= link_to "Reset", patients_path, class: "btn btn-outline-secondary btn-md" %>
    </div>

  </div>
<% end %>