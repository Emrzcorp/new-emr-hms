<div class="py-4 container">
 
 	<!-- Header -->
	<div class="row align-items-center mb-3">

	  <!-- Title + subtitle -->
	  <div class="col-12 col-md-8 col-lg-9 mb-2 mb-md-0">
	    <h4 class="fw-bold mb-1"><i class="bi bi-people me-1"></i>Patient Profile</h4>
	    <p class="text-muted small mb-0">
	      Comprehensive patient information and medical history
	    </p>
	  </div>

	  <!-- Buttons -->
	  <div class="col-12 col-md-4 col-lg-3">
	    <div class="d-flex flex-wrap gap-2 justify-content-md-end">

	      <%= link_to patients_path, class: "btn btn-outline-secondary btn-sm w-md-auto" do %>
	        ← Back
	      <% end %>

	      <%= link_to edit_doctor_patient_path(@doctor, @patient),
	        class: "btn btn-outline-primary btn-sm w-md-auto" do %>
	        <i class="bi bi-pencil me-1"></i> Edit Profile
	      <% end %>

	    </div>
	  </div>
	</div>


  <!-- Profile Card -->
  <div class="profile-card border shadow-none p-3">
    
    <!-- Header -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center profile-header mb-3 gap-2">
      
      <!-- Left Side -->
      <div class="d-flex align-items-center gap-3">
        <div class="avatar">
          <%= @patient.first_name.first.upcase %><%= @patient.last_name.first.upcase %>
        </div>

        <div>
          <h5 class="mb-1 fw-bold"><%= @patient.full_name %></h5>
          <p class="mb-0 text-muted small">
            <%= @patient.age %> years old • <%= @patient.gender %>
          </p>
        </div>
      </div>

      <!-- Right Side -->
      <div class="profile-header-right d-flex flex-wrap gap-2">

        <% if @is_active %>
          <span class="badge bg-success">Active</span>
        <% else %>
          <span class="badge bg-secondary">Inactive</span>
        <% end %>

        <% case @latest_priority %>
        <% when "high" %>
          <span class="badge bg-danger">High</span>
        <% when "medium" %>
          <span class="badge bg-warning text-dark">Medium</span>
        <% when "low" %>
          <span class="badge bg-dark">Low</span>
        <% else %>
          <span class="badge bg-secondary">Normal</span>
        <% end %>

      </div>
    </div>

    <!-- Contact Info -->
    <div class="row g-3 mb-3">
      <div class="col-12 col-md-4">
        <div class="info-box info-phone">
          <small class="d-block text-muted">
            <i class="fa-solid fa-phone fs-6 me-2"></i> Phone
          </small>
          <span class="fw-semibold"><%= @patient.phone_number %></span>
        </div>
      </div>

      <div class="col-12 col-md-4">
        <div class="info-box info-email">
          <small class="d-block text-muted">
            <i class="fa-solid fa-envelope fs-6 me-2"></i> Email
          </small>
          <span class="fw-semibold text-success"><%= @patient.email_address %></span>
        </div>
      </div>

      <div class="col-12 col-md-4">
        <div class="info-box info-insurance">
          <small class="d-block text-muted">
            <i class="fa-solid fa-heart fs-6 me-2"></i> Insurance
          </small>
          <span class="fw-semibold">NA</span>
        </div>
      </div>
    </div>

    <!-- Address -->
    <div class="info-box border bg-light p-2 rounded">
      <small class="d-block text-muted">
        <i class="fa-solid fa-location-dot fs-6 me-2"></i> Address
      </small>
      <span class="fw-semibold"><%= @patient.complete_address %></span>
    </div>
  </div>
	
	<!-- Tabs -->
	<ul class="nav nav-tabs mb-3 mt-3 flex-wrap" id="patientTabs" role="tablist">
	  <li class="nav-item">
	    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#medical-history">
	      Medical History
	    </button>
	  </li>

	  <li class="nav-item">
	    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#appointments">
	      Appointments
	    </button>
	  </li>

	  <li class="nav-item">
		  <button class="nav-link" data-bs-toggle="tab" data-bs-target="#diagnoses">
		    Diagnoses
		  </button>
		</li>
	</ul>

	<div class="tab-content">

	  <!-- Medical History -->
	  <div class="tab-pane fade show active" id="medical-history">
	    <%= render 'medical_history', patient: @patient, medical_records: @medical_records %>
	  </div>

	  <!-- Appointments -->
	  <div class="tab-pane fade" id="appointments">
	    <%= render 'appointments', patient: @patient, appointments: @appointments %>
	  </div>

	  <!-- Diagnoses -->
	  <div class="tab-pane fade" id="diagnoses">
	    <%= render 'diagnoses', patient: @patient, diagnosis: @diagnosis %>
	  </div>

	</div>
</div>