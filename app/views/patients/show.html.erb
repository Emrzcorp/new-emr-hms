<div class="py-4 container">
 
 	<!-- Header -->
	<div class="row align-items-center mb-3">
	  <!-- Back button -->
	  <div class="col-12 col-md-2 col-lg-1 mb-2 mb-md-0">
	    <%= link_to "← Back", patients_path, class: "btn btn-light w-100 w-md-auto"  %>
	  </div>

	  <!-- Title + subtitle -->
	  <div class="col-12 col-md-7 col-lg-9 text-center text-md-start mb-2 mb-md-0">
	    <h4 class="fw-bold mb-1">Patient Profile</h4>
	    <p class="text-muted small mb-0">Comprehensive patient information and medical history</p>
	  </div>

	  <!-- Edit profile button -->
	  <div class="col-12 col-md-3 col-lg-2 text-md-end">
	  	<%= link_to edit_doctor_patient_path(@doctor, @patient), 
	  		class: "btn btn-outline-primary btn-sm w-100 w-md-auto" do %>
	      <i class="bi bi-pencil me-2"></i> Edit Profile
	  	<% end %>
	    <%# <button class="btn btn-outline-primary btn-sm w-100 w-md-auto">
	    </button> %>
	  </div>
	</div>


  <!-- Profile Card -->
  <div class="profile-card border shadow-none">
    <div class="d-flex justify-content-between align-items-start profile-header mb-3">
      <!-- Left Side -->
      <div class="d-flex align-items-center gap-3">
        <div class="avatar">
        	<%= @patient.first_name.first.upcase %><%= @patient.last_name.first.upcase %>
        </div>
        <div>
          <h5 class="mb-1 fw-bold"><%= @patient.full_name %></h5>
          <p class="mb-0 text-muted small"><%= @patient.age %> years old • <%= @patient.gender %> • 
	          <%# Blood Type: O+ %>
	        </p>
        </div>
      </div>
      <!-- Right Side -->
      <div class="profile-header-right">

			  <% if @is_active %>
			    <span class="badge badge-active me-1 bg-success">Active</span>
			  <% else %>
			    <span class="badge badge-active me-1 bg-secondary">Inactive</span>
			  <% end %>

			  <% case @latest_priority %>
			  <% when "high" %>
			    <span class="badge badge-priority me-1 bg-danger">High</span>
			  <% when "medium" %>
          <span class="badge bg-warning text-dark">Medium</span>
			  <% when "low" %>
			    <span class="badge badge-priority me-1 bg-dark">Low</span>
			  <% else %>
			    <span class="badge badge-priority me-1 bg-secondary">Normal</span>
			  <% end %>

			</div>
    </div>

    <!-- Contact Info -->
    <div class="row g-3 mb-3">
      <div class="col-12 col-md-4">
        <div class="info-box info-phone">
          <small class="d-block text-muted"><i class="fa-solid fa-phone fs-6 me-2"></i> Phone</small>
          <span class="fw-semibold"><%= @patient.phone_number %></span>
        </div>
      </div>
      <div class="col-12 col-md-4">
        <div class="info-box info-email">
          <small class="d-block text-muted"><i class="fa-solid fa-envelope fs-6 me-2"></i> Email</small>
          <span class="fw-semibold text-success"><%= @patient.email_address %></span>
        </div>
      </div>
      <div class="col-12 col-md-4">
        <div class="info-box info-insurance">
          <small class="d-block text-muted"><i class="fa-solid fa-heart fs-6 me-2"></i> Insurance</small>
          <span class="fw-semibold">NA</span>
        </div>
      </div>
    </div>

    <!-- Address -->
    <div class="info-box border bg-light">
      <small class="d-block text-muted"><i class="fa-solid fa-location-dot fs-6 me-2"></i> Address</small>
      <span class="fw-semibold"><%= @patient.complete_address %></span>
    </div>
  </div>
	
	<!-- Medical Records -->
	<ul class="nav nav-tabs mb-3 mt-3" id="patientTabs" role="tablist">
	  <li class="nav-item">
	    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#medical-history">
	      Medical History
	    </button>
	  </li>
	  <li class="nav-item">
	    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#appointments">
	      Appointments
	    </button>
	  </li>
	  <li class="nav-item">
		  <button class="nav-link" data-bs-toggle="tab" data-bs-target="#diagnoses">
		    Diagnoses
		  </button>
		</li>
	</ul>

	<div class="tab-content">

	  <!-- Medical History -->
	  <div class="tab-pane fade show active" id="medical-history">
	    <%= render 'medical_history', patient: @patient, medical_records: @medical_records %>
	  </div>

	  <!-- Appointments -->
	  <div class="tab-pane fade" id="appointments">
	    <%= render 'appointments', patient: @patient, appointments: @appointments %>
	  </div>

	  <!-- Diagnoses -->
	  <div class="tab-pane fade" id="diagnoses">
	    <%= render 'diagnoses', patient: @patient, appointments: @appointments %>
	  </div>

	</div>
</div>


