<div class="col-12 col-md-7 col-lg-9 text-center text-md-start mb-2 mb-md-0">
  <h4 class="fw-bold mb-1"><i class="bi bi-calendar me-2 fs-5"></i> Appointments</h4>
  <p class="text-muted small mb-0">Past and upcoming appointments</p>
</div>
<% if appointments.present? %>
  <% appointments.each do |appt| %>
    <div class="card mb-3 mt-3 shadow-sm p-3">

      <div class="d-flex justify-content-between align-items-center">

        <div>
          <h6 class="mb-1">
            <%= appt.date.strftime("%b %d, %Y") %> • <%= appt.time %>
          </h6>
          <small class="text-muted">
            Dr. <%= appt.doctor.full_name %>
          </small>
        </div>

        <span class="badge 
          <%= case appt.status
              when "completed" then "bg-success"
              when "in_progress" then "bg-primary"
              else "bg-secondary"
              end %>">
          <%= appt.status.humanize %>
        </span>

      </div>

    </div>
  <% end %>
<% else %>
  <div class="alert alert-info">No appointments found.</div>
<% end %>