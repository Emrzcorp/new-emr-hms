<div class="col-12 col-md-7 col-lg-9 text-center text-md-start mb-2 mb-md-0">
  <h4 class="fw-bold mb-1"><i class="bi bi-activity me-2 fs-5"></i> Treatments</h4>
  <p class="text-muted small mb-0">Monitor and manage patient treatments and medications</p>
</div>
<div class="tab-pane fade show active" id="treatments">
  <% if @patient.treatments.present? %>
    <% @patient.treatments.order(created_at: :desc).each do |t| %>
      <div class="card mb-2 p-3 mt-2">

        <div class="d-flex justify-content-between mb-2">
          <div>
            <h5 class="fw-bold mb-1">
              <%= t.treatment_name&.humanize.presence || "NA" %>
            </h5>
            <small class="text-muted">
              Treatment Date: <%= t.treatment_start_date.strftime("%Y-%m-%d") if t.treatment_start_date %> • <%= t.treatment_type&.humanize.presence || "NA" %>
            </small>
          </div>

          <div class="mt-2">
            <span class="badge bg-info"><%= t.priority&.humanize.presence || "NA" %></span>
            <span class="badge bg-success"><%= t.status&.humanize.presence || "NA" %></span>
          </div>
        </div>

        <div class="row text-center mb-3">
          <div class="col-md-3 mb-2">
            <div class="p-2 rounded bg-light">
              <small>Medication</small>
              <div class="fw-bold text-danger"><%= t.medication.presence || "NA" %></div>
            </div>
          </div>

          <div class="col-md-3 mb-2">
            <div class="p-2 rounded bg-light">
              <small>Dosage</small>
              <div class="fw-bold text-primary"><%= t.dosage.presence || "NA" %></div>
            </div>
          </div>

          <div class="col-md-3 mb-2">
            <div class="p-2 rounded bg-light">
              <small>Frequency</small>
              <div class="fw-bold text-success"><%= t.frequency.presence || "NA" %></div>
            </div>
          </div>

          <div class="col-md-3 mb-2">
            <div class="p-2 rounded bg-light">
              <small>Duration</small>
              <div class="fw-bold text-purple"><%= t.duration.presence || "NA" %></div>
            </div>
          </div>
        </div>

        <p class="bg-light p-2 rounded small mb-3"><strong>Patient Instruction:</strong> <%= t.patient_instructions&.humanize.presence || "NA" %></p>
        <p class="bg-light p-2 rounded small mb-3"><strong>Clinical Notes:</strong> <%= t.clinical_notes&.humanize.presence || "NA" %></p>
        <p class="bg-light p-2 rounded small mb-3"><strong>Description:</strong> <%= t.description&.humanize.presence || "NA" %></p>

        <small>Follow-up : <span class="text-primary"><%= t.next_review_date.presence || "NA" %></span></small>
      </div>
    <% end %>
  <% else %>
    <div class="alert alert-info mt-2">No treatments found.</div>
  <% end %>
</div>
