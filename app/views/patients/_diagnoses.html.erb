<div class="col-12 col-md-7 col-lg-9 text-center text-md-start mb-2 mb-md-0">
  <h4 class="fw-bold mb-1"><i class="fa-solid fa-stethoscope me-2 fs-5"></i> Diagnoses</h4>
  <%# <p class="text-muted small mb-0">Past and upcoming appointments</p> %>
</div>
<div class="tab-pane fade" id="diagnoses">
  <% @patient.diagnoses.order(created_at: :desc).each do |d| %>
    <div class="card mb-2 p-3">
      <h6><%= d.primary_diagnosis %></h6>
      <small class="text-muted"><%= d.icd_code %></small>

      <div class="mt-2">
        <span class="badge bg-info"><%= d.severity %></span>
        <span class="badge bg-success"><%= d.status %></span>
      </div>

      <p class="mt-2"><strong>Symptoms:</strong> <%= d.symptoms %></p>
      <p><strong>Notes:</strong> <%= d.notes %></p>

      <small>Follow-up: <%= d.follow_up_date %></small>
    </div>
  <% end %>
</div>