<div class="container my-4">

  <!-- Header -->
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-2 mt-2">
    <div class="mb-3 mb-md-0">
      <h3 class="mb-0"><i class="fa-solid fa-vial"></i> Laboratory Results</h3>
      <small class="text-muted">View and manage patient test results and lab reports</small>
    </div>
  </div>

  <% if @lab_results.present? %>
    <% @lab_results.each do |t| %>
      <div class="card border rounded-3 p-4 mb-2 shadow-none">
        
        <!-- Top -->
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-2">
          <div>
            <h5 class="fw-bold mb-1">
              <%# <i class="fa-solid fa-vial text-primary me-2"></i> %>
              <%= t.test_name.humanize %>
            </h5>
            <small class="text-muted">
              <%= t.patient.full_name %> • <%= t.test_type || "NA" %>
            </small>
          </div>

          <div class="d-flex flex-wrap gap-1">
            <% case t.status %>
            <% when "Completed" %>
              <span class="badge bg-success">Completed</span>
            <% when "Pending" %>
              <span class="badge bg-warning text-dark">Pending</span>
            <% when "In Progress" %>
              <span class="badge bg-info text-dark">In Progress</span>
            <% else %>
              <span class="badge bg-secondary"><%= t.status %></span>
            <% end %>

            <!-- Priority -->
            <% case t.priority %>
            <% when "Stat" %>
              <span class="badge bg-danger">Stat</span>
            <% when "Urgent" %>
              <span class="badge bg-warning text-dark">Urgent</span>
            <% else %>
              <span class="badge bg-secondary">Routine</span>
            <% end %>
          </div>
        </div>

        <hr>

        <!-- Middle -->
        <div class="row g-3">
          <div class="col-md-6">
            <h6 class="section-title fw-bold mb-1">Test Information</h6>
            <p class="mb-1"><strong>Ordered:</strong> <%= t.test_date %></p>
            <p class="mb-1"><strong>Ordered by:</strong> Dr. <%= t.doctor.full_name %></p>
          </div>

          <div class="col-md-6">
            <h6 class="section-title fw-bold mb-1">Test Results</h6>

            <% if t.results.present? %>

              <% rows = t.results.split("\n") %>

              <% rows.first(3).each do |row| %>
                <% name, value, range = row.split("|") %>

                <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center p-2 mb-2 rounded gap-1"
                     style="background-color: #f8f9fa; font-size: 0.85rem;">

                  <!-- LEFT -->
                  <div class="d-flex align-items-center py-1">
                    <i class="bi bi-check-circle-fill text-success me-2" style="font-size: 0.75rem;"></i>
                    <span><%= name %></span>
                  </div>

                  <!-- RIGHT -->
                  <div class="text-end">
                    <div class="fw-semibold text-success">
                      <%= value %>
                    </div>
                    <%# <small class="text-muted"> %>
                      <%# Ref: <%#= range %>
                    <%# </small> %>
                  </div>

                </div>
              <% end %>

              <% if rows.size > 3 %>
                <small class="text-muted">+ <%= rows.size - 3 %> more</small>
              <% end %>

            <% else %>
              <small class="text-muted">No results</small>
            <% end %>

          </div>

          <div class="mt-2">
            <strong>Clinical Notes:</strong>
            <div class="bg-light p-2 rounded small mb-3">
              <%= t.additional_notes.titleize.presence || "NA" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="alert alert-info mt-2">No Treatment detail found.</div>
  <% end %>
</div>