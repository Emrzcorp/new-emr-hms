<div class="my-5 mt-3 container">
  <!-- Header -->
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-2">
    <div class="mb-3 mb-md-0">
      <h3 class="mb-0"><i class="fa-solid fa-stethoscope"></i> Diagnoses Management</h3>
      <small class="text-muted">Track and manage patient diagnoses and treatment progress</small>
    </div>

      <% if current_user.doctor? %>
        <button class="btn btn-primary btn-sm rounded-3"
          data-bs-toggle="modal"
          data-bs-target="#diagnosesModal">
          + New Diagnosis
        </button>
      <% end %>

      <!-- Modal -->
      <div class="modal fade" id="diagnosesModal" tabindex="-1" aria-labelledby="diagnosesModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
          <div class="modal-content">
            <div class="modal-header">
              <h1 class="modal-title fs-5" id="diagnosesModalLabel"><i class="fa-solid fa-stethoscope me-1"></i> Add New Diagnosis
                <br>
                <p class="text-muted fs-6">Create a new diagnosis record for a patient.</p>
              </h1>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
              <%= render 'diagnoses/form', diagnosis: Diagnosis.new %>
            </div>
          </div>
        </div>
      </div>
  </div>

  <!-- Summary Cards -->
  <div class="row g-3 mb-4 mt-2">
    <div class="col-6 col-md-3">
      <div class="card-summary bg-light">
        <span><i class="fa-solid fa-user fs-6 me-2"></i> <b>Total Diagnoses</b></span>
        <h5><%= @total_diagnoses %></h5>
      </div>
    </div>

    <div class="col-6 col-md-3">
      <div class="card-summary" style="background-color: #e6f9e8;">
        <span><i class="fa-solid fa-heart fs-6 me-2"></i> <b>Active Cases</b></span>
        <h5><%= @active_cases %></h5>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card-summary" style="background-color: #fff4e5;">
        <span><i class="fa-solid fa-triangle-exclamation fs-6 me-2"></i> <b>Resolving</b></span>
        <h5><%= @resolving_cases %></h5>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card-summary" style="background-color: #f4e8ff;">
        <span><i class="fa-solid fa-calendar fs-6 me-2"></i> <b>Follow-up Required</b></span>
        <h5><%= @follow_up_required %></h5>
      </div>
    </div>
  </div>

  <!-- Patient Directory -->
  <div class="card rounded-3 p-3">
    <h5>Search & Filter Diagnoses</h5>
    <p class="text-muted">
      Find specific diagnoses using search and filter options
    </p>
    <!-- Filters -->
    <div class="row g-2 mb-3">
      <div class="col-12 col-md-6">
        <%= text_field_tag :query, params[:query],
            placeholder: "Search by patient name, diagnosis, or ICD...",
            class: "form-control" %>
      </div>
      <div class="col-6 col-md-3">
        <%= select_tag :severity,
            options_for_select(["All Severities","Mild","Moderate","Severe"], params[:severity]),
            class: "form-select" %>
      </div>
      <div class="col-6 col-md-3">
         <%= select_tag :status,
            options_for_select(["All Statuses","Active","Resolved"], params[:status]),
            class: "form-select" %>
      </div>
    </div>
  </div>

  <% if @diagnoses.present? %>
    <div class="row g-4 mt-1">
      <% @diagnoses.each do |d| %>
        <div class="col-12 col-lg-12 mb-2">
          <div class="appointment-card border shadow-none rounded p-3">
            <div class="d-flex justify-content-between align-items-start flex-wrap">
              <div class="d-flex align-items-center mb-3 mb-md-0">
                <div class="rounded-circle bg-secondary text-white fw-bold d-flex align-items-center justify-content-center me-3"
                     style="width: 45px; height: 45px; font-size: 1.1rem;">
                  <%= d.primary_diagnosis.first.upcase %>
                </div>
                <div>
                  <h5 class="mb-1"><%= d.primary_diagnosis.titleize %></h5>
                  <small class="text-muted">
                    Patient : <%= d.patient.full_name %> • 
                    ICD-10 : <%= d.icd_code %>
                  </small>
                </div>
              </div>

              <div class="text-end">
               <% case d.severity %>
                <% when "Severe" %>
                  <span class="badge bg-danger">Severe</span>
                <% when "Moderate" %>
                  <span class="badge bg-warning text-dark">Moderate</span>
                <% else %>
                  <span class="badge bg-success">Mild</span>
                <% end %>

                <% if d.status == "Active" %>
                  <span class="badge bg-primary">Active</span>
                <% else %>
                  <span class="badge bg-secondary">Resolved</span>
                <% end %>
              </div>
            </div>

            <hr>

            <div class="row mt-3">
              <div class="col-sm-6">
                <h6 class="mb-3">Clinical Information</h6>
                <p><strong>First Diagnosed:</strong> <%= d.diagnoses_start_date.presence || "NA" %></p>
                <p><strong>Last Updated:</strong> <%= d.updated_at.strftime("%Y-%m-%d").presence || "NA" %></p>
                <p><strong>Treating Physician:</strong> Dr. <%= d.doctor.full_name.presence || "NA" %></p>
              
                <p><strong>Presenting Symptoms:</strong></p>
                <div class="d-flex flex-wrap gap-2">
                  <% if d.symptoms.present? %>
                    <% d.symptoms.split(",").each do |symptom| %>
                      <div class="px-3 py-1 rounded-pill d-flex align-items-center"
                           style="background-color: #f1f3f5; font-size: 0.85rem;">
                        
                        <i class="bi bi-exclamation-triangle text-muted me-2" style="font-size: 0.75rem;"></i>
                        
                        <span><%= symptom.strip %></span>
                      </div>
                    <% end %>
                  <% else %>
                    <p class="text-muted">No symptoms recorded</p>
                  <% end %>
                </div>
              </div>
              <div class="col-sm-6">
              <h6 class="mb-3">Treatment Overview</h6>

              <% if d.treatments.any? %>
                <% d.treatments.each do |t| %>
                  <div class="">
                    <div class="d-flex justify-content-between align-items-center">
                      
                      <!-- Treatment Name -->
                      <div>
                        <strong><%= t.treatment_name %></strong><br>
                        <small class="text-muted">
                          <%= t.medication.presence || "No medication" %>
                        </small>
                      </div>
                    </div>

                    <!-- Extra Info -->
                    <small class="text-muted">
                      <b>Dosage:</b> <%= t.dosage.presence || "NA" %> |
                      <b>Frequency:</b> <%= t.frequency.presence || "NA" %>
                    </small>
                  </div>
                <% end %>
              <% else %>
                <p class="text-muted">No treatment added</p>
              <% end %>
            </div>
            </div>

            <div class="mt-2">
              <strong>Clinical Notes:</strong>
              <div class="border rounded bg-light p-2 mt-1" style="min-height: 50px;">
                <%= d.notes.titleize.presence || "NA" %>
              </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap">
              <small>
                <i class="bi bi-calendar me-2"></i> Next Follow-up :
                <span class="text-primary">
                  <%= d.follow_up_date&.strftime("%b %d, %Y") || "NA" %></span>
              </small>

              <div class="d-flex gap-2 mt-2 mt-md-0">
                <!-- Edit -->
                <% if current_user.doctor? %>
                  <%= link_to edit_diagnosis_path(d), class: "btn btn-outline-secondary btn-sm" do %>
                    <i class="bi bi-pencil"></i> Edit
                  <% end %>
                <% end %>
                
                <!-- View -->
                <%= link_to diagnosis_path(d), class: "btn btn-outline-primary btn-sm" do %>
                  <i class="bi bi-eye"></i> View
                <% end %>
              </div>
            </div>            
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="alert alert-info mt-4 text-center">No Diagnosis detail found.</div>
  <% end %>
</div>
