<%= form_with model: medical_record, scope: :medical_record, data: { turbo_frame: "_top" } do |f| %>
  <h5>Visit Information</h5>
  <div class="row mb-3">
    <div class="col-md-6">
      <%= f.label :patient_id, "Patient *" %>
      <%= f.collection_select :patient_id, @patients, :id, :full_name, { prompt: "Select patient" }, class: "form-select #{'is-invalid' if medical_record.errors[:patient_id].present?}" %>

      <% if medical_record.errors[:patient_id].present? %>
        <div class="invalid-feedback d-block">
          <%= medical_record.errors.full_messages_for(:patient_id).first %>
        </div>
      <% end %>
    </div>
    <div class="col-md-6">
      <%= f.label :visit_date, "Visit Date *" %>
      <%= f.date_field :visit_date,
          class: "form-control #{'is-invalid' if medical_record.errors[:visit_date].present?}" %>

      <% if medical_record.errors[:visit_date].present? %>
        <div class="invalid-feedback d-block">
          <%= medical_record.errors.full_messages_for(:visit_date).first %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="row mb-3">
    <div class="col-md-6">
      <%= f.label :visit_type, "Visit Type *" %>
      <%= f.select :visit_type, MedicalRecord::VISIT_TYPES, { prompt: "Select visit type" }, class: "form-select #{'is-invalid' if medical_record.errors[:visit_type].present?}" %>

      <% if medical_record.errors[:visit_type].present? %>
        <div class="invalid-feedback d-block">
          <%= medical_record.errors.full_messages_for(:visit_type).first %>
        </div>
      <% end %>
    </div>

    <div class="col-md-6">
      <%= f.label :doctor_name, "Attending Physician" %>

      <input type="text"
             class="form-control bg-light"
             value="<%= current_user.doctor.full_name %>"
             readonly>
    </div>
  </div>

  <h5>Clinical Information</h5>
  <div class="mb-3">
    <%= f.label :diagnosis, "Diagnosis *" %>
    <%= f.text_field :diagnosis,
        class: "form-control #{'is-invalid' if medical_record.errors[:diagnosis].present?}",
        placeholder: "Primary diagnosis" %>

    <% if medical_record.errors[:diagnosis].present? %>
      <div class="invalid-feedback d-block">
        <%= medical_record.errors.full_messages_for(:diagnosis).first %>
      </div>
    <% end %>
  </div>

  <div class="mb-3">
    <%= f.label :symptoms %>
    <%= f.text_field :symptoms,
        class: "form-control #{'is-invalid' if medical_record.errors[:symptoms].present?}", placeholder: "Enter Symptoms" %>

    <% if medical_record.errors[:symptoms].present? %>
      <div class="invalid-feedback d-block">
        <%= medical_record.errors.full_messages_for(:symptoms).first %>
      </div>
    <% end %>
  </div>

  <div class="mb-3">
    <%= f.label :treatment_provided, "Treatment Provided" %>
    <%= f.text_field :treatment_provided,
        class: "form-control #{'is-invalid' if medical_record.errors[:treatment_provided].present?}", placeholder: "Treatment given during visit" %>

    <% if medical_record.errors[:treatment_provided].present? %>
      <div class="invalid-feedback d-block">
        <%= medical_record.errors.full_messages_for(:treatment_provided).first %>
      </div>
    <% end %>
  </div>

  <h5>Vital Signs</h5>
  <div class="row mb-3">
    <div class="col-md-3">
      <%= f.label :blood_pressure, "Blood Pressure" %>
      <%= f.text_field :blood_pressure,
          class: "form-control #{'is-invalid' if medical_record.errors[:blood_pressure].present?}", placeholder: "120/80" %>

      <% if medical_record.errors[:blood_pressure].present? %>
        <div class="invalid-feedback d-block">
          <%= medical_record.errors.full_messages_for(:blood_pressure).first %>
        </div>
      <% end %>
    </div>
    <div class="col-md-3">
      <%= f.label :heart_rate, "Heart Rate" %>
      <%= f.text_field :heart_rate,
          class: "form-control #{'is-invalid' if medical_record.errors[:heart_rate].present?}", placeholder: "72 bpm" %>

      <% if medical_record.errors[:heart_rate].present? %>
        <div class="invalid-feedback d-block">
          <%= medical_record.errors.full_messages_for(:heart_rate).first %>
        </div>
      <% end %>
    </div>
    <div class="col-md-3">
      <%= f.label :temperature, "Temperature" %>
      <%= f.text_field :temperature,
          class: "form-control #{'is-invalid' if medical_record.errors[:temperature].present?}", placeholder: "98.6°F" %>

      <% if medical_record.errors[:temperature].present? %>
        <div class="invalid-feedback d-block">
          <%= medical_record.errors.full_messages_for(:temperature).first %>
        </div>
      <% end %>
    </div>
    <div class="col-md-3">
      <%= f.label :weight, "Weight" %>
      <%= f.text_field :weight,
          class: "form-control #{'is-invalid' if medical_record.errors[:weight].present?}", placeholder: "165 lbs" %>

      <% if medical_record.errors[:weight].present? %>
        <div class="invalid-feedback d-block">
          <%= medical_record.errors.full_messages_for(:weight).first %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :clinical_notes, "Clinical Notes & Follow-up" %>
    <%#= f.text_area :clinical_notes, class: "form-control", rows: 3 %>

    <%= f.text_area :clinical_notes,
        class: "form-control #{'is-invalid' if medical_record.errors[:clinical_notes].present?}", placeholder: "Enter Clinical Notes", rows: 3 %>

    <% if medical_record.errors[:clinical_notes].present? %>
      <div class="invalid-feedback d-block">
        <%= medical_record.errors.full_messages_for(:clinical_notes).first %>
      </div>
    <% end %>
  </div>

  <div class="mb-3">
    <%= f.label :follow_up_date, "Follow-up Date" %>
    <%= f.date_field :follow_up_date,
        class: "form-control #{'is-invalid' if medical_record.errors[:follow_up_date].present?}", placeholder: "Enter Follow-up Date" %>

    <% if medical_record.errors[:follow_up_date].present? %>
      <div class="invalid-feedback d-block">
        <%= medical_record.errors.full_messages_for(:follow_up_date).first %>
      </div>
    <% end %>
  </div>

  <div class="mt-3">
    <%= f.submit "Save Record", class: "btn btn-primary" %>
    <%= link_to "Cancel", medical_records_path, class: "btn btn-secondary" %>
  </div>
<% end %>
