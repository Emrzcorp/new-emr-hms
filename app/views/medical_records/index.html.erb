<div class="container mt-3">
  <!-- Header -->
  <div class="row align-items-center mb-4">
    <div class="col-md-8">
      <h3 class="mb-0"><i class="bi bi-file-earmark-text"></i> Medical History</h3>
      <small class="text-muted">Comprehensive medical records and patient history</small>
    </div>
    <div class="col-md-4 text-md-end mt-3 mt-md-0">
      <% if current_user.doctor.present? %>
        <%= link_to 'javascript:void(0)', class: "btn btn-outline-secondary btn-sm rounded-3 me-2 mb-2" do %>
          <i class="bi bi-download"></i> Export Records
        <% end %>

        <%= link_to new_medical_record_path, class: 'btn btn-primary btn-sm rounded-3 mb-2', data: { bs_toggle: 'modal', bs_target: "#appointmentModal" }  do %>
          <i class="fa-solid fa-plus me-2"></i> New Record
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Modal -->
  <% if current_user.doctor.present? %>
    <div class="modal fade" id="appointmentModal" tabindex="-1" aria-labelledby="appointmentModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
          <div class="modal-header">
            <div>
              <h5 class="modal-title" id="appointmentModalLabel"><i class="bi bi-file-earmark-text me-2"></i> Add Medical Record</h5>
              <p class="text-muted mb-0">Create a new medical record for a patient visit.</p>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <%= render 'medical_records/form', medical_record: @medical_record %>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Summary Cards -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
      <div class="card-summary bg-light p-3 text-center rounded shadow-sm" style="min-height: 110px;" >
        <span class="d-block mb-1"><i class="bi-file-earmark-text fs-5 me-1"></i><b>Total Records</b></span>
        <h5 class="mb-0"><%= @total_records %></h5>
      </div>
    </div>

    <div class="col-6 col-md-3">
      <div class="card-summary p-3 text-center rounded shadow-sm" style="background-color: #e6f9e8; min-height: 110px;">
        <span class="d-block mb-1"><i class="bi bi-activity fs-5 me-1"></i><b>This Week</b></span>
        <h5 class="mb-0"><%= @this_week_records %></h5>
      </div>
    </div>

    <div class="col-6 col-md-3">
      <div class="card-summary p-3 text-center rounded shadow-sm" style="background-color: #fff4e5; min-height: 110px;">
        <span class="d-block mb-1"><i class="bi bi-heart fs-5 me-1"></i><b>Follow-ups Due</b></span>
        <h5 class="mb-0"><%= @follow_ups_due %></h5>
      </div>
    </div>

    <div class="col-6 col-md-3">
      <div class="card-summary p-3 text-center rounded shadow-sm" style="background-color: #f4e8ff; min-height: 110px;">
        <span class="d-block mb-1"><i class="bi bi-clock fs-5 me-1"></i><b>Active Cases</b></span>
        <h5 class="mb-0"><%= @active_cases %></h5>
      </div>
    </div>
  </div>

  <!-- Filters Section -->
  <%= render 'medical_records/search' %>

  <!-- Medical Records -->
  <% if @medical_records.present? %>
    <div class="row g-4">
      <% @medical_records.each do |record| %>
        <div class="col-12 col-lg-12 mb-1">
          <div class="appointment-card shadow-none border rounded-3 p-3">
            <div class="d-flex justify-content-between align-items-start flex-wrap">
              <div class="d-flex align-items-center mb-3 mb-md-0">
                <div class="rounded-circle bg-secondary text-white fw-bold d-flex align-items-center justify-content-center me-3"
                     style="width: 45px; height: 45px; font-size: 1.1rem;">
                  <%= record.patient.first_name.first.upcase %><%= record.patient.last_name.first.upcase %>
                </div>
                <div>
                  <h5 class="mb-1"><%= record.patient.full_name %></h5>
                  <small class="text-muted">
                    Patient ID: <%= record.patient.id %> • 
                    <%= record.visit_date.strftime("%b %d, %Y") if record.visit_date.present? %>
                  </small>
                </div>
              </div>

              <div>
                <span class="badge bg-success"><%= record.visit_type.presence || "NA"  %></span>
              </div>
            </div>

            <hr>

            <div class="row mt-3">
              <div class="col-sm-6">
                <h6 class="section-title fw-bold mb-1">Diagnosis & Treatment</h6>
                <p class="mb-1"><strong>Diagnosis:</strong> <%= record.diagnosis.titleize.presence || "NA" %></p>
                <p class="mb-1"><strong>Treatment:</strong> <%= record.treatment_provided.titleize.presence || "NA" %></p>
                <p class="mb-1"><strong>Doctor:</strong> Dr. <%= record.doctor.full_name.presence || "NA" %></p>
                <p class="mb-1"><strong>Symptoms:</strong> <%= record.symptoms.titleize.presence || "NA" %></p>
              </div>
              <div class="col-sm-6">
                <h6 class="section-title fw-bold mb-1">Vital Signs</h6>
                <p class="mb-1"><strong>BP:</strong> <%= record.blood_pressure.presence || "NA"  %></p>
                <p class="mb-1"><strong>Temp:</strong> <%= record.temperature.presence || "NA"  %></p>
                <p class="mb-1"><strong>HR:</strong> <%= record.heart_rate.presence || "NA"  %></p>
                <p class="mb-1"><strong>Weight:</strong> <%= record.weight.presence || "NA"  %></p>
              </div>
            </div>

            <div class="mt-1">
              <strong>Clinical Notes:</strong>
              <div class="bg-light p-2 rounded small mb-3">
                <%= record.clinical_notes.titleize.presence || "NA" %>
              </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap">
              <small>Next Follow-up: <span class="text-primary"><%= record.follow_up_date %></span></small>
              <%= link_to medical_record_path(record), class: "btn btn-primary btn-sm mt-2 mt-md-0" do %>
                <i class="bi bi-eye"></i>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="alert alert-info mt-4 text-center">No medical records found.</div>
  <% end %>

  <% if @medical_records %>
    <div class="col-lg-12 mt-3 mb-3">
      <div class="d-flex justify-content-between bg-light rounded align-items-center py-3">
        <div class="page_info ms-3 text-black">
          <%= page_entries_info @medical_records %>
        </div>
        <% if params[:per_page ].present? %>
          <%= will_paginate @medical_records, :params =>  {per_page: @per_page }, renderer: WillPaginate::ActionView::BootstrapLinkRenderer %>
        <% else %>
          <%= will_paginate @medical_records, renderer: WillPaginate::ActionView::BootstrapLinkRenderer %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
